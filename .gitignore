# ##############################################################################
# Dependencies and Core
# ##############################################################################
# We never commit the vendor folder or Drupal core.
# They are managed via 'composer install'.
/vendor/
/web/core/

# Contributed modules, themes, and profiles.
# Only custom code should be committed.
/web/modules/contrib/
/web/themes/contrib/
/web/profiles/contrib/
/web/libraries/

# ##############################################################################
# Site-specific files (Uploads and Settings)
# ##############################################################################
# Ignore user-uploaded files (images, documents, etc.)
/web/sites/*/files/

# Ignore local settings and services.
/web/sites/*/settings.local.php
/web/sites/*/services.local.yml

# If you use a simple settings.php, it's often better to ignore it
# and provide a settings.php.example instead to hide passwords.
# /web/sites/default/settings.php

# ##############################################################################
# DDEV and Local Environment
# ##############################################################################
# Ignore local DDEV overrides and snapshots.
.ddev/.env*
.ddev/db_snapshots/
.ddev/commands/host/

# ##############################################################################
# IDE and OS specific files
# ##############################################################################
.idea/
.vscode/
.DS_Store
*.swp
