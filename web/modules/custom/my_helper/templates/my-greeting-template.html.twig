{{ attach_library('my_helper/greeting-stats') }}

<div class="cmf-greeting-card">
  <h2>
    {{ greeting_text }}, <span class="user-name">{{ user_name }}</span>!
  </h2>

  <p>
    Welcome to our platform.
    Currently, there are <strong>{{ user_count }}</strong> users registered!<br>
    Time: <span class="live-time">{{ visit_time }}</span>
  </p>

  <div class="footer">
    This block is generated by a Service, styled via CSS library, and rendered via Twig.
  </div>
</div>
