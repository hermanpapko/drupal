<div class="cmf-greeting-card" style="
    border: 3px solid #4a90e2;
    padding: 25px;
    border-radius: 12px;
    background-color: #f9f9f9;
    font-family: sans-serif;
    max-width: 500px;
    margin: 20px 0;">

  <h2 style="margin-top: 0; color: #2c3e50;">
    {{ greeting_text }}, <span style="color: #4a90e2;"> {{ user_name }}</span>!
  </h2>

  <p style="font-size: 1.1em; line-height: 1.5;">
    Welcome to our platform.
    Currently, there are <strong>{{ user_count }}</strong> users registered!
  </p>

  <footer style="margin-top: 15px; border-top: 1px solid #ddd; padding-top: 10px; font-style: italic; color: #777;">
    This block is generated by a Service and rendered via Twig.
  </footer>
</div>
